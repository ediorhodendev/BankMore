{
  "info": {
    "name": "BankMore - End to End",
    "_postman_id": "7c9ce4a0-7f86-4d36-a65d-7b5ddf5a8e01",
    "description": "Coleção Postman para testar Account API, Transfer API e cenários de erro do projeto BankMore.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrlAccount",
      "value": "http://localhost:5001"
    },
    {
      "key": "baseUrlTransfer",
      "value": "http://localhost:5002"
    },
    {
      "key": "tokenJoao",
      "value": ""
    },
    {
      "key": "tokenMaria",
      "value": ""
    },
    {
      "key": "contaJoao",
      "value": ""
    },
    {
      "key": "contaMaria",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Criar conta João",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrlAccount}}/api/accounts"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"João Silva\",\n  \"cpf\": \"52998224725\",\n  \"password\": \"123456\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201 ou 400 se já existir', function () { pm.expect([201,400]).to.include(pm.response.code); });",
              "if (pm.response.code === 201) { var data = pm.response.json(); if (data.accountNumber) pm.collectionVariables.set('contaJoao', data.accountNumber); }"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Criar conta Maria",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrlAccount}}/api/accounts"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Maria Souza\",\n  \"cpf\": \"39053344705\",\n  \"password\": \"654321\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201 ou 400 se já existir', function () { pm.expect([201,400]).to.include(pm.response.code); });",
              "if (pm.response.code === 201) { var data = pm.response.json(); if (data.accountNumber) pm.collectionVariables.set('contaMaria', data.accountNumber); }"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Login João",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrlAccount}}/api/auth/login"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"52998224725\",\n  \"password\": \"123456\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var data = pm.response.json();",
              "if (data.token) pm.collectionVariables.set('tokenJoao', data.token);",
              "if (data.accountNumber) pm.collectionVariables.set('contaJoao', data.accountNumber);"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Login Maria",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
